<Project>
  <!-- ========================================================================
       FxDependent - the "umph" path

       Framework-dependent publish. ~5MB artifact. Requires the .NET 10
       runtime to be installed on the target box. Use this when:
         - You're iterating fast and want small artifacts to scp
         - You're managing multiple services that share a runtime
         - You want CVE patches via apt-get upgrade dotnet-runtime-10.0

       Install .NET 10 runtime on the target first:
         # Microsoft package feed (one-time setup, per Ubuntu version)
         wget https://packages.microsoft.com/config/ubuntu/24.04/packages-microsoft-prod.deb
         sudo dpkg -i packages-microsoft-prod.deb
         sudo apt update && sudo apt install -y dotnet-runtime-10.0 aspnetcore-runtime-10.0

       Publish:
         dotnet publish -c Release -p:PublishProfile=FxDependent

       Output:
         bin/Release/net10.0/linux-x64/publish/SerenRuntimeHost.dll
         bin/Release/net10.0/linux-x64/publish/wwwroot/
         ... and a pile of .dll deps
    ======================================================================== -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net10.0\linux-x64\publish\</PublishDir>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <PublishProtocol>FileSystem</PublishProtocol>

    <!-- Framework-dependent: do NOT bundle the runtime. -->
    <SelfContained>false</SelfContained>

    <!-- Multi-file deployment - keep .dll deps as separate files. Single-file
         is possible here too but adds startup overhead with no real win for
         the framework-dependent case. -->
    <PublishSingleFile>false</PublishSingleFile>

    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
